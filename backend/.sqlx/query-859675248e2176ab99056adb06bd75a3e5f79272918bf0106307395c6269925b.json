  "query": "\n            SELECT id, tenant_id, user_id, type as \"type\", title, content, read_at, created_at\n            FROM notifications\n            WHERE tenant_id = $1 AND (user_id = $2 OR user_id IS NULL)\n            ORDER BY created_at DESC\n            LIMIT $3\n            ",
