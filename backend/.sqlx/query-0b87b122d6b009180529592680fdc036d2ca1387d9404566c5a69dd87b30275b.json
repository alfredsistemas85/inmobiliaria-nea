{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, first_name, last_name, email, phone, created_at\n        FROM clients\n        WHERE tenant_id = $1 AND deleted_at IS NULL\n          AND ($2::timestamptz IS NULL OR created_at >= $2)\n          AND ($3::timestamptz IS NULL OR created_at <= $3)\n        ORDER BY created_at DESC\n        ",
